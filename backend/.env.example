# Application
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/doctor-clinic

# Auth
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRY=30d

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Rate limiting (window in minutes, max requests per window)
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300

# Twilio WhatsApp (optional - leaves WhatsApp in stub mode if blank)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI Features (optional - runs in intelligent demo mode when blank)
# Supports: openai or gemini
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
